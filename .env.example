# Nexora CMS — Configuração de Ambiente
# Copie este arquivo para .env e ajuste os valores

# === Servidor ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_TIMEOUT=30s

# === Banco de Dados ===
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nexora
DATABASE_PASSWORD=nexora_secret
DATABASE_NAME=nexora
DATABASE_SSLMODE=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === Autenticação ===
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# === OAuth ===
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/callback

# === Armazenamento ===
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_ENDPOINT=

# === Cache ===
CACHE_DRIVER=memory
CACHE_TTL=5m

# === Modo de Desenvolvimento ===
DEBUG=true
LOG_LEVEL=debug
LOG_FORMAT=console
